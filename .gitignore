# Repo-root gitignore. The project's own .gitignore lives at
# Automation-main/.gitignore and only covers paths under that subdir.
# This file closes the gap for anything that lands at the repo root
# (e.g. an accidentally-placed .env, like the one that was force-pushed
# out on 2026-05-21).

# Secrets — never commit these
.env
.env.*
!.env.example
auth_state.json

# IDE / editor
.vscode/
.idea/
.claude/settings.local.json

# Build artifacts (root-level strays from PyInstaller).
# These exist only at build time — anyone with the source can rebuild
# via Automation-main/build_exe.bat. They MUST stay out of git because
# GitHub rejects single files >100 MB and the bundled .exe is ~320 MB.
ZiraQARunner.exe
*.spec
